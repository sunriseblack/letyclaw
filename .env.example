# Required
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather

# AI Backend — Claude CLI is the default (requires Claude subscription)
# Set ANTHROPIC_API_KEY to use the API directly instead
# ANTHROPIC_API_KEY=sk-ant-...

# Model selection (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Paths (defaults are platform-appropriate)
# VAULT_PATH=./vault
# SESSIONS_DIR=./sessions

# Optional: OpenAI for DALL-E image generation and TTS
# OPENAI_API_KEY=sk-...

# Optional: Vapi for AI voice calls
# VAPI_API_KEY=
# VAPI_PHONE_NUMBER_ID=
# VAPI_ASSISTANT_ID=

# Optional: Alpha Vantage for market data
# ALPHA_VANTAGE_API_KEY=

# Optional: Whisper for voice transcription
# WHISPER_MODEL=/path/to/ggml-base.bin
